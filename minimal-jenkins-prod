version: '3.8'
services:
  jenkins:
    image: jenkins/jenkins:2.554
    container_name: jenkins-prod
    restart: unless-stopped
    ports:
      - "8080:8080"   # UI Port
      - "50000:50000" # Agent communication port
    volumes:
      - jenkins_data:/var/jenkins_home
      - /var/run/docker.sock:/var/run/docker.sock # Optional: if you need to run Docker builds from Jenkins
    environment:
      - JAVA_OPTS=-Xmx2g # Example: Limit JVM heap memory
    user: "1000:1000" # Run as non-root user (ID 1000 is default for jenkins user)

volumes:
  jenkins_data:
    driver: local
